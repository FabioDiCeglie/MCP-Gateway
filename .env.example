# Upstream MCP server URL (Streamable HTTP).
# Local dev default — no need to set this if mcp-server runs on :8000.
GATEWAY_UPSTREAM_URL=http://127.0.0.1:8000/mcp

# Audit DB — file path for local SQLite (default: data/audit.db).
# GATEWAY_AUDIT_DB_PATH=data/audit.db

# JWT auth (M5). HS256 shared secret — unset = auth disabled.
# Gateway validates; mcp-client auto-signs when this is set (local dev only).
GATEWAY_JWT_SECRET=change-me

# Postgres (Docker Compose). Copy to .env and change for non-dev use.
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=audit
