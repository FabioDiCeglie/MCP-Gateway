# Copy to .env and adjust for your environment.
#
# Local `uv run` vs Docker Compose — some gateway vars differ by host/network.
# Compose overrides GATEWAY_UPSTREAM_URL, GATEWAY_AUDIT_DB_PATH, and
# GATEWAY_OTEL_EXPORTER_ENDPOINT in docker/docker-compose.yaml.

# Upstream MCP server (Streamable HTTP).
# Local:  http://127.0.0.1:8000/mcp  (default if unset)
# Docker: compose overrides → http://mcp-server:8000/mcp
GATEWAY_UPSTREAM_URL=http://127.0.0.1:8000/mcp

# Audit DB.
# Local:  data/audit.db  (SQLite, default if unset)
# Docker: compose overrides → postgresql://USER:PASS@postgres:5432/DB
GATEWAY_AUDIT_DB_PATH=data/audit.db

# JWT auth. Same in both environments — unset = auth disabled.
# Gateway validates; mcp-client auto-signs when this is set (local dev only).
GATEWAY_JWT_SECRET=your-secret-at-least-32-chars-long

# OpenTelemetry tracing. Unset = tracing disabled.
# Local:  http://127.0.0.1:4318/v1/traces  (Jaeger on host)
# Docker: compose overrides → http://jaeger:4318/v1/traces
GATEWAY_OTEL_EXPORTER_ENDPOINT=http://127.0.0.1:4318/v1/traces
GATEWAY_OTEL_SERVICE_NAME=mcp-gateway

# Postgres — Docker Compose only (used by postgres service + audit URL above).
# Not needed for local uv run (SQLite).
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=audit
